# Logs
npm-debug.log*
yarn-error.log*

# IDE settings (keep VS Code config if needed)
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# System files
.DS_Store
Thumbs.db
